/**
 * LeetCode 509 - Fibonacci Number
 *
 * Problem:
 * The Fibonacci numbers are defined as:
 *
 * F(0) = 0
 * F(1) = 1
 *
 * F(n) = F(n - 1) + F(n - 2), for n > 1
 *
 * Given n, return F(n).
 *
 * Approach:
 * 1. Handle base cases for 0 and 1
 * 2. Use two variables to store previous Fibonacci numbers
 * 3. Iteratively calculate the next Fibonacci value
 * 4. Return the nth Fibonacci number
 *
 * Time Complexity: O(n)
 * Space Complexity: O(1)
 */

class Solution {

    public int fib(int n) {

        // Base cases
        if (n <= 1) {
            return n;
        }

        int first = 0;
        int second = 1;

        // Calculate Fibonacci iteratively
        for (int i = 2; i <= n; i++) {

            int current = first + second;

            first = second;
            second = current;
        }

        return second;
    }
}
