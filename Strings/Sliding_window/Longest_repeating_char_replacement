// Problem: Longest Repeating Character Replacement
// Link: https://leetcode.com/problems/longest-repeating-character-replacement/
// Difficulty: Medium

// Approach:
// Use sliding window + frequency array.
// Track the most frequent character in the current window.
// If window size - maxCount > k, shrink the window.
// Keep updating the maximum valid window size.

// Time Complexity: O(n)
// Space Complexity: O(1)

class Solution {
    public int characterReplacement(String s, int k) {
        int[] scount = new int[26];
        int left = 0;
        int maxcount = 0;
        int maxLen = 0;

        for (int right = 0; right < s.length(); right++) {
            scount[s.charAt(right) - 'A']++;
            maxcount = Math.max(maxcount, scount[s.charAt(right) - 'A']);

            if ((right - left + 1) - maxcount > k) {
                scount[s.charAt(left) - 'A']--;
                left++;
            }

            maxLen = Math.max(maxLen, right - left + 1);
        }

        return maxLen;
    }
}
