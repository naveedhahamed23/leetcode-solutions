import java.util.Arrays;

/**
 * LeetCode 16 - 3Sum Closest
 *
 * Problem:
 * Given an integer array nums and an integer target,
 * return the sum of the three integers
 * closest to the target.
 *
 * You may assume that each input has exactly one solution.
 *
 * Approach:
 * 1. Sort the array
 * 2. Fix one element at a time
 * 3. Use two pointers to find the closest sum
 * 4. Update closest sum whenever a better result is found
 * 5. Move pointers based on comparison with target
 *
 * Time Complexity: O(n²)
 * Space Complexity: O(1)
 */

class Solution {

    public int threeSumClosest(int[] nums, int target) {

        int n = nums.length;

        // Sort array for two-pointer approach
        Arrays.sort(nums);

        int closestSum = nums[0] + nums[1] + nums[2];

        // Fix one element
        for (int i = 0; i < n - 2; i++) {

            // Skip duplicates
            if (i > 0 && nums[i] == nums[i - 1]) {
                continue;
            }

            int left = i + 1;
            int right = n - 1;

            // Two-pointer search
            while (left < right) {

                int sum = nums[i] + nums[left] + nums[right];

                // Update closest sum
                if (Math.abs(target - sum) <
                    Math.abs(target - closestSum)) {

                    closestSum = sum;
                }

                // Move left pointer
                if (sum < target) {
                    left++;
                }

                // Move right pointer
                else if (sum > target) {
                    right--;
                }

                // Exact target found
                else {
                    return sum;
                }
            }
        }

        return closestSum;
    }
}
