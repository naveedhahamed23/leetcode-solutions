/**
 * LeetCode 977 - Squares of a Sorted Array
 *
 * Problem:
 * Given an integer array nums sorted in non-decreasing order,
 * return an array of the squares of each number
 * also sorted in non-decreasing order.
 *
 * Approach:
 * 1. Use two pointers:
 *    - left starts from beginning
 *    - right starts from end
 * 2. Compare absolute square values
 * 3. Place larger square at the end of result array
 * 4. Move corresponding pointer inward
 * 5. Continue until all elements are processed
 *
 * Time Complexity: O(n)
 * Space Complexity: O(n)
 */

class Solution {

    public int[] sortedSquares(int[] nums) {

        int n = nums.length;

        int[] result = new int[n];

        int left = 0;
        int right = n - 1;

        int pointer = n - 1;

        while (left <= right) {

            int leftSquare = nums[left] * nums[left];
            int rightSquare = nums[right] * nums[right];

            // Place larger square at current position
            if (leftSquare > rightSquare) {

                result[pointer] = leftSquare;

                left++;
            }

            else {

                result[pointer] = rightSquare;

                right--;
            }

            pointer--;
        }

        return result;
    }
}
