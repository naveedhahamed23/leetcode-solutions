// Problem: Koko Eating Bananas
// Link: https://leetcode.com/problems/koko-eating-bananas/
// Difficulty: Medium

// Approach:
// Use Binary Search on Answer.
// The goal is to find the minimum eating speed (k) such that Koko
// can finish all piles within h hours.
//
// Search space: k ∈ [1, max(piles)]
//
// For a given k:
// Calculate total hours required = sum of ceil(pile / k)
// If hours > h → k is too slow → increase k
// Else → k works → try smaller k

// Time Complexity: O(n log max(piles))
// Space Complexity: O(1)

class Solution {
    public int minEatingSpeed(int[] piles, int h) {
        int left = 1;
        int right = 0;

        // Find maximum pile (upper bound of k)
        for (int pile : piles) {
            right = Math.max(right, pile);
        }

        // Binary search on answer
        while (left < right) {
            int mid = left + (right - left) / 2;
            int hours = 0;

            // Calculate total hours needed at speed = mid
            for (int pile : piles) {
                hours += (pile + mid - 1) / mid; // ceil division
            }

            if (hours > h) {
                left = mid + 1; // too slow
            } else {
                right = mid; // valid, try smaller
            }
        }

        return left;
    }
}
