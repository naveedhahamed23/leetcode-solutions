// Problem: Check if Matrix is Similar After Cyclic Shifts
// Link: https://leetcode.com/problems/check-if-matrix-is-similar-after-cyclic-shifts/
// Difficulty: Easy

// Approach:
// For each row:
// - Even index → left shift by k
// - Odd index → right shift by k
// Compare shifted position with original

// Time Complexity: O(m * n)
// Space Complexity: O(1)

class Solution {
    public boolean areSimilar(int[][] mat, int k) {
        int m = mat.length;
        int n = mat[0].length;

        k = k % n;

        for (int i = 0; i < m; i++) {

            for (int j = 0; j < n; j++) {
                int expected;

                if (i % 2 == 0) {  // ✅ FIXED
                    expected = mat[i][(j + k) % n];  // left shift
                } else {
                    expected = mat[i][(j - k + n) % n];  // right shift
                }

                if (mat[i][j] != expected) {
                    return false;
                }
            }
        }

        return true;
    }
}
