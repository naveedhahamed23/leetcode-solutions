// Problem: Sum in a Matrix
// Link: https://leetcode.com/problems/sum-in-a-matrix/
// Difficulty: Easy

// Approach:
// 1. Sort each row in ascending order.
// 2. For each column, pick the maximum element across all rows.
// 3. Add these maximums to the result.

// Time Complexity: O(m * n log n)
// Space Complexity: O(1)

class Solution {
    public int matrixSum(int[][] nums) {
        int row = nums.length;
        int col = nums[0].length;
        int sum = 0;

        // Sort each row
        for (int i = 0; i < row; i++) {
            Arrays.sort(nums[i]);
        }

        // Pick max from each column
        for (int j = 0; j < col; j++) {
            int max = Integer.MIN_VALUE;

            for (int i = 0; i < row; i++) {
                max = Math.max(max, nums[i][j]);
            }

            sum += max;
        }

        return sum;
    }
}
