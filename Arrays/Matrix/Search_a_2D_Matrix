/**
 * LeetCode 74 - Search a 2D Matrix
 *
 * Problem:
 * Given an m x n matrix with the following properties:
 *
 * 1. Integers in each row are sorted in ascending order
 * 2. First integer of each row is greater than
 *    the last integer of the previous row
 *
 * Return true if target exists in the matrix,
 * otherwise return false.
 *
 * Approach:
 * 1. Traverse every element in the matrix
 * 2. Compare each element with target
 * 3. If target is found, return true
 * 4. Otherwise return false after full traversal
 *
 * Time Complexity: O(m × n)
 * Space Complexity: O(1)
 */

class Solution {

    public boolean searchMatrix(int[][] matrix, int target) {

        int rows = matrix.length;
        int cols = matrix[0].length;

        // Traverse matrix
        for (int i = 0; i < rows; i++) {

            for (int j = 0; j < cols; j++) {

                // Target found
                if (matrix[i][j] == target) {
                    return true;
                }
            }
        }

        // Target not found
        return false;
    }
}
