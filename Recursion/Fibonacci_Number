/**
 * LeetCode 509 - Fibonacci Number
 *
 * Approach:
 * 1. If n is 0 or 1, return n
 * 2. Recursively calculate:
 *    fib(n - 1) + fib(n - 2)
 *
 * Time Complexity: O(2^n)
 * Space Complexity: O(n)
 */

class Solution {

    public int fib(int n) {

        // Base case
        if (n == 0 || n == 1) {
            return n;
        }

        // Recursive calls
        return fib(n - 1) + fib(n - 2);
    }
}
