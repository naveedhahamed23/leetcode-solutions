/**
 * LeetCode 342 - Power of Four
 *
 * Approach:
 * 1. If n is less than or equal to 0, return false
 * 2. If n becomes 1, it is a power of four
 * 3. If n is not divisible by 4, return false
 * 4. Recursively divide n by 4
 *
 * Time Complexity: O(log n)
 * Space Complexity: O(log n)
 */

class Solution {

    public boolean isPowerOfFour(int n) {

        // Invalid case
        if (n <= 0) {
            return false;
        }

        // Base case
        if (n == 1) {
            return true;
        }

        // Not divisible by 4
        if (n % 4 != 0) {
            return false;
        }

        // Recursive call
        return isPowerOfFour(n / 4);
    }
}
